model Jobs {
    id               String          @id @default(uuid())
    recruiterId      String
    title            String
    description      String
    requirements     String
    location         String
    salaryMin        Decimal
    salaryMax        Decimal
    skills           Json?
    levelType        ExperienceLevel
    experience_limit String?
    experience_desc  String?
    employmentType   EmploymentType
    status           JobStatus
    atsKeywords      Json?
    atsMinScore      Int?
    atsWeights       Json?
    createdAt        DateTime        @default(now())
    updatedAt        DateTime        @updatedAt
    applications     Application[]
    recruiter        Auth            @relation(fields: [recruiterId], references: [id])

    @@index([title, description])
    @@index([location])
}
